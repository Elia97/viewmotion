---
import { VIEWMOTION_VERSION } from "@/lib/version";

interface Props {
  variant?: "landing" | "docs";
}

const { variant = "landing" } = Astro.props;
const versionMark = "v " + VIEWMOTION_VERSION.split(".").join("·");
---

<header
  class="sticky top-0 left-0 w-full h-14 z-50 border-b border-border bg-background/85 backdrop-blur-xl flex items-center justify-between px-6 sm:px-10 lg:px-14"
>
  <!-- Brand: serif wordmark + mono version stamp -->
  <a href="/" class="flex items-baseline gap-3 group">
    <span
      class="font-display text-xl tracking-[-0.02em] text-foreground"
      style="font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 0;">viewmotion</span
    >
    <span
      class="hidden sm:inline font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground/80 transition-colors group-hover:text-primary"
      >{versionMark}</span
    >
  </a>

  <!-- Desktop nav: monospace, all-caps, editorial -->
  <nav
    class="hidden sm:flex items-center gap-7 font-mono text-[0.72rem] uppercase tracking-[0.16em] text-muted-foreground"
  >
    {
      variant === "landing" ? (
        <>
          <a href="/docs" class="hover:text-foreground transition-colors">
            Docs
          </a>
        </>
      ) : (
        <>
          <a href="/" class="hover:text-foreground transition-colors">
            Home
          </a>
        </>
      )
    }
    <a
      href="https://www.npmjs.com/package/viewmotion"
      target="_blank"
      rel="noopener"
      class="hover:text-foreground transition-colors">npm</a
    >
    <a
      href="https://github.com/Elia97/viewmotion"
      target="_blank"
      rel="noopener"
      class="hover:text-foreground transition-colors flex items-center gap-1.5"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
        ></path>
      </svg>
      GitHub
    </a>
  </nav>

  <!-- Right controls -->
  <div class="flex items-center gap-1">
    <!-- Theme toggle — always visible -->
    <button
      id="theme-toggle"
      class="flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
      aria-label="Toggle theme"
    >
      <svg
        id="sun-icon"
        class="w-5 h-5 hidden"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <circle cx="12" cy="12" r="5"></circle>
        <path
          stroke-linecap="round"
          d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
        ></path>
      </svg>
      <svg
        id="moon-icon"
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
      </svg>
    </button>

    <!-- Docs: mobile sidebar toggle -->
    {
      variant === "docs" && (
        <button
          id="mobile-sidebar-toggle"
          class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
          aria-label="Toggle sidebar"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
            />
          </svg>
        </button>
      )
    }

    <!-- Landing: mobile nav toggle -->
    {
      variant === "landing" && (
        <button
          id="mobile-menu-btn"
          class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
          aria-label="Toggle navigation"
          aria-expanded="false"
        >
          <svg
            id="hamburger-icon"
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
          <svg
            id="close-icon"
            class="w-5 h-5 hidden"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      )
    }
  </div>
</header>

<script>
  // Single source of truth for theme toggle wiring.
  // Being in SiteHeader (shared by all layouts) this module is bundled once by
  // Astro, so only one astro:page-load listener is ever registered — no risk of
  // double-toggle when navigating between landing and docs pages.
  function syncThemeIcons(isDark: boolean) {
    document.getElementById("sun-icon")?.classList.toggle("hidden", !isDark);
    document.getElementById("moon-icon")?.classList.toggle("hidden", isDark);
  }

  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;

    // Sync icons with current state (may have been set by BaseLayout inline script)
    syncThemeIcons(document.documentElement.classList.contains("dark"));

    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      syncThemeIcons(isDark);
    });
  });
</script>
