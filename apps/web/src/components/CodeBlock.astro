---
import { Code } from "astro:components";
import type { CodeLanguage } from "astro";
import { motion } from "viewmotion";

interface Props {
  title?: string;
  code: string;
  lang: CodeLanguage;
}

const { title, code, lang } = Astro.props;
---

<div
  class="w-full border rounded-lg overflow-hidden"
  style="background: #0d1117; border-color: rgb(255 255 255 / 0.08);"
  {...motion({ preset: "blur-in", duration: 1000 })}
>
  <div
    class="p-3 border-b flex items-center justify-between gap-2"
    style="border-color: rgb(255 255 255 / 0.08);"
  >
    {title && <h3 class="font-semibold text-sm text-neutral-300">{title}</h3>}
    <button
      data-copy={code}
      aria-label="Copy code"
      title="Copy"
      class="flex items-center gap-1.5 text-xs text-neutral-500 hover:text-neutral-200 transition-colors px-2 py-1 rounded-md hover:bg-white/5 shrink-0"
    >
      <svg
        data-copy-icon
        class="w-3.5 h-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
        ></path>
      </svg>
      <span data-copy-label>Copy</span>
    </button>
  </div>
  <div class="overflow-x-auto">
    <Code
      {code}
      {lang}
      theme="github-dark"
      class="text-sm! bg-transparent! p-3 min-w-full"
    />
  </div>
</div>
