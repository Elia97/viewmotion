---
import { motion } from "viewmotion";

interface Props {
  /** Small overline label displayed above the heading (optional) */
  label?: string;
  /** Main h2 / section title. Supports HTML via set:html if needed. */
  heading: string;
  /** Subtitle / description paragraph below the heading (optional) */
  subtext?: string;
  /** Extra Tailwind classes for the outer wrapper (e.g. "mb-12") */
  class?: string;
}

const { label, heading, subtext, class: extraClass = "" } = Astro.props;
---

<div class={`text-center mb-16 ${extraClass}`}>
  {
    label && (
      <p
        class="text-primary font-semibold text-sm tracking-widest uppercase mb-3"
        {...motion({ preset: "fade-down", duration: 500 })}
      >
        {label}
      </p>
    )
  }
  <h2
    class="text-3xl md:text-5xl font-bold tracking-tight mb-4"
    {...motion({ preset: "fade-up", duration: 600 })}
    set:html={heading}
  />
  {
    subtext && (
      <p
        class="text-muted-foreground text-lg max-w-2xl mx-auto"
        {...motion({ preset: "fade-up", delay: 100, duration: 600 })}
        set:html={subtext}
      />
    )
  }
</div>
