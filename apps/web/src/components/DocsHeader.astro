---
import { VIEWMOTION_VERSION } from "@/lib/version"
import ThemeToggle from "./ThemeToggle.astro"

const versionMark = "v " + VIEWMOTION_VERSION.split(".").join("·")
---

<header
  class="fixed top-0 left-0 z-50 flex h-14 w-full items-center justify-between border-b border-border bg-background/85 px-6 backdrop-blur-xl sm:px-10 lg:px-14"
>
  <!-- Brand: serif wordmark + mono version stamp -->
  <a href="/" class="group flex items-baseline gap-3">
    <span
      class="font-display text-xl tracking-tight text-foreground"
      style="font-variation-settings: 'opsz' 24, 'SOFT' 80, 'WONK' 0;"
      >viewmotion</span
    >
    <span
      class="hidden font-mono text-[0.65rem] uppercase tracking-[0.18em] text-muted-foreground/80 transition-colors group-hover:text-primary sm:inline"
      >{versionMark}</span
    >
  </a>

  <!-- Desktop nav -->
  <nav
    class="hidden items-center gap-7 font-mono text-[0.72rem] uppercase tracking-[0.16em] text-muted-foreground sm:flex"
  >
    <a href="/" class="transition-colors hover:text-foreground">Home</a>
    <a
      href="https://www.npmjs.com/package/viewmotion"
      target="_blank"
      rel="noopener"
      class="transition-colors hover:text-foreground">npm</a
    >
    <a
      href="https://github.com/Elia97/viewmotion"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-1.5 transition-colors hover:text-foreground"
    >
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
        ></path>
      </svg>
      GitHub
    </a>
  </nav>

  <!-- Right controls -->
  <div class="flex items-center gap-1">
    <ThemeToggle />

    <!-- Mobile sidebar toggle -->
    <button
      id="mobile-sidebar-toggle"
      class="flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground sm:hidden"
      aria-label="Toggle sidebar"
    >
      <svg
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
    </button>
  </div>
</header>
