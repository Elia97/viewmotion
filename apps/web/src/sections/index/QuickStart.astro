---
import { motion, stagger } from "viewmotion";
import SectionHeader from "../../components/SectionHeader.astro";
import CodeBlock from "../../components/CodeBlock.astro";
import { snippets } from "../../utils/snippets";

const steps = [
  { n: "1", label: "Install", snippet: snippets.install },
  { n: "2", label: "Initialize", snippet: snippets.initialize },
  { n: "3", label: "Animate", snippet: snippets.animate },
];
---

<section class="py-20 px-6">
  <div class="container mx-auto">
    <SectionHeader
      label="Quick start"
      heading="Three lines to animate"
      subtext="Install, initialize, and add data attributes. That’s it."
    />

    <div
      class="grid xl:grid-cols-3 gap-8"
      {...stagger({ delay: 100, step: 100 })}
    >
      {
        steps.map(({ n, label, snippet }) => (
          <div class="min-w-0" {...motion({ preset: "scale-in" })}>
            <div class="flex items-center gap-3 mb-4">
              <span class="w-8 h-8 rounded-md bg-primary text-primary-foreground text-sm font-bold flex items-center justify-center">
                {n}
              </span>
              <h3 class="text-base font-semibold">{label}</h3>
            </div>
            <CodeBlock code={snippet.code} lang={snippet.lang} />
          </div>
        ))
      }
    </div>
  </div>
</section>
