---
import { motion, stagger } from "viewmotion";
import SectionHeader from "../../components/SectionHeader.astro";

const cards = [
  {
    n: "01",
    title: "Single observer",
    desc: "One IntersectionObserver manages all elements on the page. No per-element setup needed.",
  },
  {
    n: "02",
    title: "8 built-in presets",
    desc: "From subtle fades to directional slides. Extend with registerPreset() for custom animations.",
  },
  {
    n: "03",
    title: "Reduced motion",
    desc: "Automatically respects prefers-reduced-motion. Elements reveal instantly without animation.",
  },
  {
    n: "04",
    title: "Zero runtime deps",
    desc: "No external libraries at runtime. Pure IntersectionObserver + CSS keyframes.",
  },
  {
    n: "05",
    title: "SSR-ready",
    desc: "Works with server-rendered HTML, static pages, and any framework's SSR output.",
  },
  {
    n: "06",
    title: "Smooth scroll",
    desc: "Optional Lenis integration for buttery smooth scrolling as a peer dependency.",
  },
];
---

<section class="py-20 px-6">
  <div class="container mx-auto">
    <SectionHeader
      label="Stagger"
      heading="Cascading reveals, zero effort"
      subtext={`Wrap a container with <code class="text-primary">stagger()</code> and each
        child animates with an automatic incremental delay. Perfect for grids, lists, and cards.`}
    />

    <div
      class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5"
      {...stagger({ delay: 100, step: 200 })}
    >
      {
        cards.map(({ n, title, desc }) => (
          <div class="group border rounded-lg bg-card transition-colors duration-300 hover:border-primary p-6" {...motion({ preset: "fade-up" })}>
            <div class="text-3xl font-bold text-secondary/65 group-hover:text-secondary/80 transition-colors mb-3">
              {n}
            </div>
            <h3 class="text-base font-semibold mb-2">{title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed mb-0">
              {desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
