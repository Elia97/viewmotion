{
  "name": "viewmotion-vue",
  "version": "0.1.0",
  "description": "Vue adapter for viewmotion — v-motion directive and useMotion composable",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "author": "Elia Zarantonello <email@eliazarantonello.dev> (https://github.com/Elia97)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elia97/viewmotion.git",
    "directory": "packages/viewmotion-vue"
  },
  "homepage": "https://github.com/Elia97/viewmotion/tree/main/packages/viewmotion-vue#readme",
  "keywords": [
    "viewmotion",
    "vue",
    "motion",
    "animation",
    "reveal",
    "intersection-observer"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "viewmotion": "workspace:^",
    "vue": ">=3"
  },
  "devDependencies": {
    "viewmotion": "workspace:*",
    "vue": "^3.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
